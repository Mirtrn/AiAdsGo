# ==========================================
# 应用配置
# ==========================================
NEXT_PUBLIC_APP_URL=http://localhost:3000
# OpenClaw -> AutoAds 内部调用地址（同容器部署建议使用 127.0.0.1）
INTERNAL_APP_URL=http://127.0.0.1:3000
NODE_ENV=development

# Python Google Ads Service URL (服务账号模式)
PYTHON_ADS_SERVICE_URL=http://localhost:8001

# ==========================================
# JWT配置
# ==========================================
JWT_SECRET=your_random_64_char_hex_secret_here_please_change_in_production
JWT_EXPIRES_IN=7d

# ==========================================
# 数据库配置
# ==========================================

# SQLite数据库配置（本地开发默认）
DATABASE_PATH=./data/autoads.db
BACKUP_DIR=./data/backups
MAX_BACKUP_DAYS=30

# PostgreSQL数据库配置（生产环境优先）
# 格式: postgresql://用户名:密码@主机:端口/数据库名?参数
# 示例: postgresql://autoads:password@localhost:5432/autoads
# 示例（SSL）: postgresql://autoads:password@db-host:5432/autoads?sslmode=require
# DATABASE_URL=postgresql://autoads:password@localhost:5432/autoads

# 默认管理员密码（强烈建议生产环境设置强密码）
# 不设置则自动生成随机32位密码
# DEFAULT_ADMIN_PASSWORD=your-strong-password-here

# Google Ads 配置区块管理员密码保护
# 设置后，设置页面中 Google Ads API 区块将需要输入此密码才能查看和修改
# 防止普通用户误操作 Google Ads API 凭证
# GOOGLE_ADS_ADMIN_PASSWORD=your-google-ads-admin-password-here

# ==========================================
# Google OAuth 2.0 配置
# ==========================================
GOOGLE_CLIENT_ID=your_google_oauth_client_id
GOOGLE_CLIENT_SECRET=your_google_oauth_client_secret
GOOGLE_REDIRECT_URI=http://localhost:3000/api/auth/google/callback

# ==========================================
# Google Ads API 配置
# ==========================================
# 📖 获取步骤：
# 1. 创建Google Cloud项目：https://console.cloud.google.com/
# 2. 启用Google Ads API
# 3. 创建OAuth 2.0凭证（Web应用）
# 4. 创建MCC账户：https://ads.google.com/home/tools/manager-accounts/
# 5. 申请Developer Token（需要MCC账户）
# 6. 运行OAuth流程获取Refresh Token（访问 /api/google-ads/oauth/start）

# OAuth 2.0 配置
GOOGLE_ADS_CLIENT_ID=your_google_ads_client_id
GOOGLE_ADS_CLIENT_SECRET=your_google_ads_client_secret

# 开发者令牌（从MCC账户获取）
# 申请地址：https://ads.google.com/aw/apicenter
GOOGLE_ADS_DEVELOPER_TOKEN=your_google_ads_developer_token

# OAuth2.0刷新令牌（⚠️ 重要：通过OAuth授权流程获取）
# 获取方式：
#   方式1: 访问应用的 /api/google-ads/oauth/start 端点
#   方式2: 使用OAuth Playground: https://developers.google.com/oauthplayground/
GOOGLE_ADS_REFRESH_TOKEN=

# MCC Manager账户ID（用于API访问权限，不含连字符）
# 示例：如果MCC账户是 123-456-7890，则填写 1234567890
GOOGLE_ADS_LOGIN_CUSTOMER_ID=your_manager_account_id_without_hyphens

# 广告账户ID（可选，支持多个账户，逗号分隔，不含连字符）
# 示例：1234567890,0987654321,1111222233
GOOGLE_ADS_CUSTOMER_IDS=

# ==========================================
# Google Ads API 高级配置（可选）
# ==========================================
# API版本（默认v16，可选值：v15, v16）
GOOGLE_ADS_API_VERSION=v16

# API请求超时（毫秒，默认60000）
GOOGLE_ADS_REQUEST_TIMEOUT_MS=60000

# 批量操作配置（默认1000）
GOOGLE_ADS_BATCH_SIZE=1000

# 报表查询分页大小（默认10000）
GOOGLE_ADS_REPORT_PAGE_SIZE=10000

# 日志级别（debug/info/warn/error，默认info）
GOOGLE_ADS_LOG_LEVEL=info

# Google Ads 文案政策防护模式: strict | balanced | preserve-volume
# - strict: 最严格，高风险类关键词更容易被丢弃
# - balanced: 默认，敏感词优先改写，仅极高风险硬拦截
# - preserve-volume: 更保量，尽量改写，最少硬拦截
GOOGLE_ADS_POLICY_GUARD_MODE=balanced

# ==========================================
# AI API 配置
# ==========================================
# ⚠️ 当前系统统一使用 LiteLLM 中转服务（openllmapi.com）
# AI 配置通过【设置页面】在数据库中管理，环境变量为降级备用
#
# 数据库配置项（在 /settings 页面配置）：
#   - ai_provider     = litellm
#   - litellm_api_key = <你的 openllmapi Key>
#   - litellm_base_url = https://openllmapi.com（默认，可不填）
#   - litellm_model   = google/gemini-3-flash-preview（或其他支持的模型）
#
# 以下为降级备用（数据库未配置时生效）：
# GEMINI_API_KEY=
# 输出异常大时是否记录完整 AI 响应（默认 false）
# GEMINI_LOG_FULL_RESPONSE=false

# ==========================================
# 数据加密配置 (AES-256-GCM)
# ==========================================
ENCRYPTION_KEY=your_32_byte_hex_encryption_key_here_64_chars
ENCRYPTION_IV_LENGTH=16

# ==========================================
# 代理配置 (可选)
# ==========================================
PROXY_ENABLED=false
PROXY_HOST=
PROXY_PORT=
PROXY_USERNAME=
PROXY_PASSWORD=

# ==========================================
# 安全配置
# ==========================================
BCRYPT_SALT_ROUNDS=10
MAX_LOGIN_ATTEMPTS=5
LOCKOUT_DURATION_MINUTES=15

# Cloudflare Turnstile CAPTCHA配置
# 获取地址：https://dash.cloudflare.com/
# 是否启用CAPTCHA验证（true/false，默认false）
NEXT_PUBLIC_CAPTCHA_ENABLED=false
# CAPTCHA Site Key（前端使用）
NEXT_PUBLIC_TURNSTILE_SITE_KEY=your_turnstile_site_key
# CAPTCHA Secret Key（后端验证使用）
TURNSTILE_SECRET_KEY=your_turnstile_secret_key

# ==========================================
# 数据同步配置
# ==========================================
SYNC_INTERVAL_HOURS=6
ENABLE_AUTO_SYNC=true

# ==========================================
# 链接检查配置
# ==========================================
LINK_CHECK_ENABLED=true
LINK_CHECK_CRON=0 2 * * *
LINK_CHECK_TIMEOUT_MS=10000

# ==========================================
# 备份配置
# ==========================================
BACKUP_CRON_SCHEDULE=0 3 * * *
ENABLE_AUTO_BACKUP=true

# ==========================================
# 速率限制配置
# ==========================================
RATE_LIMIT_WINDOW_MS=900000
RATE_LIMIT_MAX_REQUESTS=100

# ==========================================
# Redis配置
# ==========================================
REDIS_URL=redis://localhost:6379
REDIS_PASSWORD=
REDIS_DB=0
REDIS_KEY_PREFIX=autoads:
# 生产环境建议保持 true：Redis 不可用时跳过 click-farm 入队，避免内存队列堆积 OOM
CLICK_FARM_REQUIRE_REDIS_IN_PRODUCTION=true

# ==========================================
# 日志配置
# ==========================================
LOG_LEVEL=info
LOG_FILE_PATH=./logs/app.log

# ==========================================
# OpenClaw 网关配置
# ==========================================
# OpenClaw 网关认证令牌（用于 API 调用鉴权）
OPENCLAW_GATEWAY_TOKEN=your_openclaw_gateway_token_here
# OpenClaw 网关端口（默认 18789）
OPENCLAW_GATEWAY_PORT=18789
# OpenClaw 进程最大堆内存（MB，默认 1536）
NODE_MAX_OLD_SPACE_SIZE_OPENCLAW=1536
# OpenClaw 日志级别（debug | info | warn | error，默认 info）
OPENCLAW_LOG_LEVEL=info

# ==========================================
# CI/CD 配置 (GitHub Actions 变量，非本地环境变量)
# ==========================================
# 以下配置在 GitHub Repository Settings 中设置:
# Settings → Secrets and variables → Actions → Variables
#
# ENABLE_CLOUD_RUN_DEPLOY=false
#   - 控制是否执行 deploy-to-cloud-run 步骤
#   - 值: true (启用) 或 false/空 (禁用)
#   - 默认: 禁用 (不设置或设为 false)
