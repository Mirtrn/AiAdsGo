{
  "manifest_version": 3,
  "name": "AutoAds YP Session Capture",
  "description": "Capture YeahPromos cookies and send them to AutoAds products session endpoint.",
  "version": "1.0.0",
  "permissions": [
    "cookies",
    "tabs",
    "scripting",
    "activeTab"
  ],
  "host_permissions": [
    "https://*.yeahpromos.com/*"
  ],
  "background": {
    "service_worker": "background.js"
  },
  "action": {
    "default_title": "YP Session Capture",
    "default_popup": "popup.html"
  }
}
