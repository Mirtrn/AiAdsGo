# ============================================
# AutoAds 生产环境变量配置示例
# ============================================
# 使用说明:
# 1. 复制此文件为 .env.production
# 2. 填写实际的配置值
# 3. 确保 .env.production 已添加到 .gitignore（不要提交到版本控制）
# ============================================

# ============================================
# 数据库配置
# ============================================
# PostgreSQL 连接字符串
# 格式: postgresql://用户名:密码@主机:端口/数据库名
DATABASE_URL=postgresql://autoads:your_password@localhost:5432/autoads

# 如果使用 Docker Compose 中的 PostgreSQL，使用服务名作为主机
# DATABASE_URL=postgresql://autoads:your_password@postgres:5432/autoads

# ============================================
# Google Ads API 凭证
# ============================================
# 开发者令牌（从 Google Ads API Center 获取）
GOOGLE_ADS_DEVELOPER_TOKEN=your_developer_token_here

# OAuth 2.0 客户端 ID（从 Google Cloud Console 获取）
GOOGLE_ADS_CLIENT_ID=your_client_id.apps.googleusercontent.com

# OAuth 2.0 客户端密钥
GOOGLE_ADS_CLIENT_SECRET=your_client_secret_here

# 刷新令牌（通过 OAuth 2.0 授权流程获取）
GOOGLE_ADS_REFRESH_TOKEN=your_refresh_token_here

# 客户账户 ID（可选，格式: 1234567890，不带连字符）
# GOOGLE_ADS_CUSTOMER_ID=1234567890

# ============================================
# Google AI (Gemini) API
# ============================================
# Google AI API Key（从 Google AI Studio 获取）
GOOGLE_AI_API_KEY=your_google_ai_api_key_here

# ============================================
# JWT 认证配置
# ============================================
# JWT 密钥（至少 32 个字符，建议使用随机生成的强密码）
# 生成命令: openssl rand -base64 32
JWT_SECRET=your_jwt_secret_key_min_32_characters_long_here

# JWT 过期时间（可选，默认 7 天）
# JWT_EXPIRES_IN=7d

# ============================================
# 应用配置
# ============================================
# Node.js 环境
NODE_ENV=production

# 应用监听端口（内部端口，不建议修改）
PORT=3000

# 主机名（不建议修改）
HOSTNAME=0.0.0.0

# ============================================
# 时区配置
# ============================================
# 时区设置（影响定时任务执行时间）
TZ=Asia/Shanghai

# ============================================
# 日志配置（可选）
# ============================================
# 日志级别: debug | info | warn | error
# LOG_LEVEL=info

# ============================================
# 数据备份配置（可选）
# ============================================
# 备份文件存储目录（容器内路径）
# BACKUP_DIR=/app/backups

# 数据保留天数（默认 90 天）
# DATA_RETENTION_DAYS=90

# ============================================
# PostgreSQL 数据库配置（仅当使用 Docker Compose 时）
# ============================================
# 数据库名称
POSTGRES_DB=autoads

# 数据库用户名
POSTGRES_USER=autoads

# 数据库密码（强密码）
POSTGRES_PASSWORD=changeme_to_strong_password

# ============================================
# 其他配置（可选）
# ============================================
# Next.js 禁用遥测
NEXT_TELEMETRY_DISABLED=1
