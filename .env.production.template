# ==========================================
# AutoAds 生产环境最简配置模板
# ==========================================
# 说明：
# ✅ 必需 - 应用无法启动或核心功能无法运行
# 🔶 推荐 - 影响核心功能体验
# ⚪ 可选 - 优化和增强功能

# ==========================================
# ✅ 应用基础配置（必需）
# ==========================================
NEXT_PUBLIC_APP_URL=https://your-domain.com
NODE_ENV=production

# ==========================================
# ✅ JWT 认证配置（必需）
# ==========================================
# 生成方法: node -e "console.log(require('crypto').randomBytes(32).toString('hex'))"
JWT_SECRET=请替换为64位随机十六进制字符串
JWT_EXPIRES_IN=7d

# ==========================================
# ✅ PostgreSQL 数据库配置（必需）
# ==========================================
# 格式: postgresql://用户名:密码@主机:端口/数据库名?参数
# 示例: postgresql://postgres:password@localhost:5432/autoads?directConnection=true
DATABASE_URL=postgresql://postgres:your_password@your_host:5432/autoads?directConnection=true

# ==========================================
# ✅ 数据加密密钥（必需 - 必须与开发环境一致）
# ==========================================
# ⚠️ 重要：此密钥必须与开发环境完全一致，否则无法解密迁移的配置数据
# 生成方法: node -e "console.log(require('crypto').randomBytes(32).toString('hex'))"
ENCRYPTION_KEY=请使用开发环境相同的32字节十六进制密钥
ENCRYPTION_IV_LENGTH=16

# ==========================================
# ✅ Google OAuth 认证配置（必需）
# ==========================================
# 获取方法: https://console.cloud.google.com/apis/credentials
GOOGLE_CLIENT_ID=your_google_oauth_client_id.apps.googleusercontent.com
GOOGLE_CLIENT_SECRET=GOCSPX-your_google_oauth_client_secret
GOOGLE_REDIRECT_URI=https://your-domain.com/api/auth/google/callback

# ==========================================
# 🔶 Redis 缓存配置（推荐）
# ==========================================
# 用于缓存热点数据、会话管理、速率限制
# 格式: redis://用户名:密码@主机:端口
REDIS_URL=redis://default:your_redis_password@your_redis_host:6379

# ==========================================
# 🔶 AI API 配置（推荐 - 核心功能需要）
# ==========================================
# 注意：管理员配置导入后，数据库中的 AI 配置优先级更高
# 如果数据库中未配置 Vertex AI，则使用此 Gemini API Key

# Gemini API Key (备用 AI 引擎)
# 获取方法: https://makersuite.google.com/app/apikey
GEMINI_API_KEY=your_gemini_api_key_here
# 输出异常大时是否记录完整 AI 响应（默认 false）
# GEMINI_LOG_FULL_RESPONSE=false

# ==========================================
# 🔶 Google Ads API 配置（推荐 - 核心功能需要）
# ==========================================
# 注意：管理员配置导入后，数据库中的 Google Ads 配置优先级更高
# 这些环境变量仅作为备用配置

# OAuth 2.0 配置（通常与 Google OAuth 相同）
GOOGLE_ADS_CLIENT_ID=your_google_ads_client_id.apps.googleusercontent.com
GOOGLE_ADS_CLIENT_SECRET=GOCSPX-your_google_ads_client_secret

# Developer Token（从 Google Ads MCC 账户获取）
# 申请地址: https://ads.google.com/aw/apicenter
GOOGLE_ADS_DEVELOPER_TOKEN=your_developer_token

# MCC Manager 账户 ID（不含连字符）
# 示例: 如果账户是 123-456-7890，则填写 1234567890
GOOGLE_ADS_LOGIN_CUSTOMER_ID=your_manager_account_id

# ==========================================
# ⚪ 代理配置（可选 - 某些地区访问 Google API 需要）
# ==========================================
PROXY_ENABLED=false
PROXY_URL=

# ==========================================
# ⚪ 安全配置（可选 - 使用默认值）
# ==========================================
BCRYPT_SALT_ROUNDS=10
MAX_LOGIN_ATTEMPTS=5
LOCKOUT_DURATION_MINUTES=15

# ==========================================
# ⚪ 数据同步配置（可选 - 使用默认值）
# ==========================================
SYNC_INTERVAL_HOURS=6
ENABLE_AUTO_SYNC=true

# ==========================================
# ⚪ 链接检查配置（可选 - 使用默认值）
# ==========================================
LINK_CHECK_ENABLED=true
LINK_CHECK_CRON=0 2 * * *
LINK_CHECK_TIMEOUT_MS=10000

# ==========================================
# ⚪ 备份配置（可选 - 使用默认值）
# ==========================================
BACKUP_CRON_SCHEDULE=0 3 * * *
ENABLE_AUTO_BACKUP=true
BACKUP_DIR=./data/backups
MAX_BACKUP_DAYS=30

# ==========================================
# ⚪ 速率限制配置（可选 - 使用默认值）
# ==========================================
RATE_LIMIT_WINDOW_MS=900000
RATE_LIMIT_MAX_REQUESTS=100

# ==========================================
# ⚪ 日志配置（可选 - 使用默认值）
# ==========================================
LOG_LEVEL=info
LOG_FILE_PATH=./logs/app.log

# ==========================================
# ⚪ Google Ads API 高级配置（可选 - 使用默认值）
# ==========================================
GOOGLE_ADS_API_VERSION=v16
GOOGLE_ADS_REQUEST_TIMEOUT_MS=60000
GOOGLE_ADS_BATCH_SIZE=1000
GOOGLE_ADS_REPORT_PAGE_SIZE=10000
GOOGLE_ADS_LOG_LEVEL=info
